#!/usr/bin/env bash
# Set wallpaper via swww. Pass a path or pick random from ~/Pictures/wallpapers/
# Usage: wallpaper-set [/path/to/image]
WALLPAPER_DIR="${WALLPAPER_DIR:-$HOME/Pictures/wallpapers}"
STATE_FILE="$HOME/.config/current-wallpaper"

if [[ $# -ge 1 ]]; then
  wall="$1"
else
  if [[ ! -d "$WALLPAPER_DIR" ]]; then
    notify-send -u low "wallpaper-set" "No directory at $WALLPAPER_DIR — add images there" 2>/dev/null || true
    exit 0
  fi
  mapfile -t walls < <(find "$WALLPAPER_DIR" -maxdepth 2 -type f \
    \( -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" \
       -o -iname "*.gif" -o -iname "*.webp" \) | sort)
  if [[ ${#walls[@]} -eq 0 ]]; then
    notify-send -u low "wallpaper-set" "No images found in $WALLPAPER_DIR" 2>/dev/null || true
    exit 0
  fi
  wall="${walls[RANDOM % ${#walls[@]}]}"
fi

swww img "$wall" \
  --transition-type grow \
  --transition-pos 0.5,0.5 \
  --transition-duration 1 \
  --transition-fps 60

echo "$wall" > "$STATE_FILE"
