{
  "hyprland/window": {
    "format": "{title}",
    "rewrite": {
      "(.*) — Zen Browser": "$1",
      "(.*) - Discord": "$1"
    },
    "separate-outputs": true,
    "icon": true
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "",
    "all-outputs": false,
    "active-only": false,
    "show-special": true,
    "persistent-workspaces": {
      "*": [11, 12, 13, 14, 15, 16, 17, 18]
    },
    "format-icons": {
      "11": "一",
      "12": "二",
      "13": "三",
      "14": "四",
      "15": "五",
      "16": "六",
      "17": "七",
      "18": "八"
    }
  },
  "tray": {
    "icon-size": 26,
    "spacing": 7,
    "reverse-direction": true
  },
  "pulseaudio": {
    "scroll-step": 2,
    "format": "{icon}{volume}%",
    "format-muted": "<span color=\"#b4befe\">󰝟 </span>...",
    "format-icons": {
      "default": ["<span color=\"#89b4fa\"> </span>"],
      "headphone": ["<span color=\"#89b4fa\">󰋋 </span>"]
    },
    "on-click": "pamixer -t"
  },
  "group/cpu-memory": {
    "orientation": "inherit",
    "modules": ["cpu", "memory"]
  },
  "custom/pacman": {
    "format": " {}",
    "interval": 120,
    "exec": "python3 ~/.config/waybar/scripts/arch_updates",
    "on-click": "ghostty -e bash -c 'checkupdates; echo; read -p \"…\"'"
  },
  "cpu": {
    "interval": 1,
    "format": "<span color=\"#f9e2af\"> </span>{usage}%  "
  },
  "memory": {
    "interval": 1,
    "format": "<span color=\"#a6e3a1\"> </span>{used:0.1f}G/{total:0.1f}G RAM"
  },
  "clock": {
    "format": "{:%a %b %d  %H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "format": {
        "months": "<span color='#a6e3a1'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'>{}</span>",
        "today": "<span background='#f38ba8' color='#1e1e2e'><b>{}</b></span>"
      }
    }
  },
  "custom/arch": {
    "format": "",
    "tooltip": "Arch Linux"
  },
  "cava": {
    "framerate": 60,
    "autosens": 1,
    "sensitivity": 3,
    "bars": 24,
    "lower_cutoff_freq": 50,
    "higher_cutoff_freq": 14000,
    "method": "pulse",
    "stereo": false,
    "waves": true,
    "noise_reduction": 0.33,
    "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]
  }
}
